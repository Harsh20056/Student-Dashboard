<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Dashboard - Update Password</title>
<link rel="stylesheet" href="/style.css" />  </head>
  <body>
    
    <div class="dashboard-wrapper">
      <!-- Top Branding Container Section -->
      <header class="dashboard-header">
        <h1>Security Panel</h1>
        <div class="user-badge">
          Student ID &nbsp;•&nbsp; <strong><%= id %></strong>
        </div>
      </header>

      <!-- Main Interaction Form Elements -->
      <form
        onsubmit="return validateForm();"
        action="/api/auth/update-password/<%= id %>"
        method="POST"
      >
        <div class="form-field">
          <label for="password">New Authentication Password</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="••••••••"
            required
          />
        </div>

        <div class="form-field">
          <label for="confirmPassword">Verify New Password</label>
          <input
            type="password"
            id="confirmPassword"
            placeholder="••••••••"
            required
          />
        </div>

        <div class="action-panel">
          <button type="submit">Update Password</button>
        </div>
      </form>
    </div>

    <!-- JavaScript Event Validation Logic -->
     <script src="/validate.js"></script>
  </body>
</html>